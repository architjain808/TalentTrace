{
  "name": "hr-email-finder",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "dev": "nodemon",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "build:android": "eas build --platform android --profile preview",
    "build:android:prod": "eas build --platform android --profile production",
    "build:local": "powershell -Command \"cd android; .\\gradlew.bat assembleDebug -PreactNativeArchitectures=arm64-v8a\"",
    "build:local:release": "powershell -Command \"cd android; .\\gradlew.bat assembleRelease -PreactNativeArchitectures=arm64-v8a\"",
    "build:local:all-arch": "powershell -Command \"cd android; .\\gradlew.bat assembleRelease\"",
    "install:apk": "adb install -r android/app/build/outputs/apk/debug/app-debug.apk",
    "install:apk:release": "adb install -r android/app/build/outputs/apk/release/app-release.apk",
    "dev:android": "npx expo run:android",
    "prebuild": "expo prebuild --platform android --clean"
  },
  "dependencies": {
    "@expo/metro-runtime": "~55.0.6",
    "@react-native-async-storage/async-storage": "^2.2.0",
    "axios": "^1.13.6",
    "expo": "~55.0.4",
    "expo-auth-session": "~55.0.6",
    "expo-constants": "~55.0.7",
    "expo-crypto": "~55.0.8",
    "expo-linking": "~55.0.7",
    "expo-router": "~55.0.3",
    "expo-secure-store": "~55.0.8",
    "expo-status-bar": "~55.0.4",
    "expo-web-browser": "~55.0.9",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-native": "0.83.2",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-toast-message": "^2.3.3",
    "react-native-web": "^0.21.0"
  },
  "devDependencies": {
    "babel-preset-expo": "^55.0.10",
    "nodemon": "^3.1.14"
  },
  "private": true
}
